{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AAE Manifest",
  "description": "Schema za validaciju manifest.json fajla AAE projekta",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["file", "title_en", "title_sr", "description_en", "description_sr", "tags", "author", "date"],
    "additionalProperties": false,
    "properties": {
      "file": {
        "type": "string",
        "description": "Naziv fajla slike (samo ime fajla, bez putanje)",
        "pattern": "^[\\w\\-]+\\.(jpg|jpeg|png|webp)$"
      },
      "title_en": {
        "type": "string",
        "description": "Naslov slike na engleskom",
        "minLength": 1
      },
      "title_sr": {
        "type": "string",
        "description": "Naslov slike na srpskom",
        "minLength": 1
      },
      "description_en": {
        "type": "string",
        "description": "Opis slike na engleskom",
        "minLength": 1
      },
      "description_sr": {
        "type": "string",
        "description": "Opis slike na srpskom",
        "minLength": 1
      },
      "tags": {
        "type": "array",
        "description": "Lista AAE tagova",
        "items": {
          "type": "string",
          "pattern": "^[A-Z0-9]+$"
        },
        "minItems": 1
      },
      "author": {
        "type": "string",
        "description": "Autor slike",
        "minLength": 1
      },
      "date": {
        "type": "string",
        "description": "Datum kreiranja u formatu YYYY-MM-DD",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      }
    }
  }
}
